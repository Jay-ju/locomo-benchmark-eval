# === Evaluation Mode Configuration ===
# This file serves as a template. Copy it to .env and fill in your values.

# === 1. Agent Mode Configuration (Default) ===
# Used when running with `--mode agent` (connects to OpenClaw API)
# OPENAI_BASE_URL=http://localhost:18789/v1
# OPENAI_API_KEY=openclaw-secret
# OPENAI_MODEL=ark/doubao-seed-2-0-pro-260215

# === 2. Direct Pipeline Configuration ===
# Used when running with `--mode direct` (Internal RAG pipeline)
# Defaults below are for Volcengine (Doubao)
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=your-volcengine-api-key
OPENAI_MODEL=doubao-pro-32k

# === 3. Embedding Configuration (Direct Mode Only) ===
# Choose ONE of the following options:

# Option A: Doubao / OpenAI (Remote) - Default
EMBEDDING_PROVIDER=doubao
EMBEDDING_API_KEY=your-volcengine-api-key
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
EMBEDDING_MODEL=doubao-embedding-vision
VECTOR_DIM=2048

# Option B: Local HuggingFace / BGE (Local)
# Requires `pip install sentence-transformers`
# EMBEDDING_PROVIDER=local-huggingface
# EMBEDDING_MODEL=BAAI/bge-m3
# VECTOR_DIM=1024

# === 4. Network Proxy (Optional) ===
# Required if downloading models from HuggingFace in restricted networks
# http_proxy=http://sys-proxy-rd-relay.byted.org:8118
# https_proxy=http://sys-proxy-rd-relay.byted.org:8118
# no_proxy=code.byted.org
